# Existing Gemini integration
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# OpenAI integration for ARAAK NAMA AI agents
# Store the real key in the hosting platform secrets. Never commit it.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-5-mini"

# Safety mode: supervised | sandbox | autonomous
ARAAK_AI_MODE="supervised"
# Keep false until official channel connectors, audit logs and approvals are tested.
ARAAK_AUTO_PUBLISH="false"

# Application and persistence
PORT="3000"
APP_URL="MY_APP_URL"
DATABASE_URL=""
REDIS_URL=""
KNOWLEDGE_STORAGE_BUCKET=""

# Academy and publishing connectors
ACADEMY_LMS_BASE_URL=""
ACADEMY_LMS_API_KEY=""
WHATSAPP_ACCESS_TOKEN=""
LINKEDIN_ACCESS_TOKEN=""
X_ACCESS_TOKEN=""
